APP_NAME="Personal Navigation"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8100

# Database: mysql 或 sqlite
DB_CONNECTION=mysql

# MySQL 配置
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=personal_nav
DB_USERNAME=root
DB_PASSWORD=

# SQLite 配置（DB_CONNECTION=sqlite 时使用）
DB_SQLITE_PATH=storage/database/personal_nav.sqlite

# Admin User Initialization
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Redis 缓存配置（首页整页缓存使用）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=3

# Session
SESSION_LIFETIME=120

# 隐私空间密码（留空则不启用隐私功能）
PRIVATE_SPACE_PASSWORD=
